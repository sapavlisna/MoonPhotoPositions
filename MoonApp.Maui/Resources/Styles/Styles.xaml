    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceL}, Dark={StaticResource SurfaceD}}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{AppThemeBinding Light={StaticResource TopbarL}, Dark={StaticResource TopbarD}}" />
        <Setter Property="Shell.ForegroundColor" Value="{AppThemeBinding Light={StaticResource InkL}, Dark={StaticResource InkD}}" />
        <Setter Property="Shell.TitleColor" Value="{AppThemeBinding Light={StaticResource InkL}, Dark={StaticResource InkD}}" />
        <Setter Property="Shell.DisabledColor" Value="{AppThemeBinding Light={StaticResource MutedL}, Dark={StaticResource MutedD}}" />
        <Setter Property="Shell.UnselectedColor" Value="{AppThemeBinding Light={StaticResource MutedL}, Dark={StaticResource MutedD}}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{AppThemeBinding Light={StaticResource Magenta}, Dark={StaticResource White}}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{AppThemeBinding Light={StaticResource Magenta}, Dark={StaticResource White}}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray200}}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource TopbarL}, Dark={StaticResource TopbarD}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource InkL}, Dark={StaticResource InkD}}" />
        <Setter Property="IconColor" Value="{AppThemeBinding Light={StaticResource InkL}, Dark={StaticResource InkD}}" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource Magenta}, Dark={StaticResource White}}" />
        <Setter Property="UnselectedTabColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray950}}" />
        <Setter Property="SelectedTabColor" Value="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray200}}" />
    </Style>

    <!-- ===== Redesign · pomocné styly ===== -->

    <!-- Sekundární / neutrální tlačítko (ovládání mapy, grafu, ikony) -->
    <Style TargetType="Button" x:Key="Ghost">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource InkL}, Dark={StaticResource InkD}}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SubtleL}, Dark={StaticResource SubtleD}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MutedL}, Dark={StaticResource MutedD}}" />
                            <Setter Property="Opacity" Value="0.5" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Malý „eyebrow" popisek -->
    <Style TargetType="Label" x:Key="Eyebrow">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MutedL}, Dark={StaticResource MutedD}}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="1.6" />
    </Style>

    <!-- Datová / monospace hodnota -->
    <Style TargetType="Label" x:Key="Meta">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MutedL}, Dark={StaticResource MutedD}}" />
        <Setter Property="FontFamily" Value="monospace" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- Karta (sekce Nastavení) -->
    <Style TargetType="Border" x:Key="Card">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ElevatedL}, Dark={StaticResource ElevatedD}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource HairL}, Dark={StaticResource HairD}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="16" />
        </Setter>
        <Setter Property="Padding" Value="16,10" />
    </Style>

    <!-- Nadpis sekce -->
    <Style TargetType="Label" x:Key="SectionTitle">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource InkL}, Dark={StaticResource InkD}}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!-- Hodnotové pole v řádku Nastavení -->
    <Style TargetType="Entry" x:Key="ValueEntry">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource InkL}, Dark={StaticResource InkD}}" />
        <Setter Property="FontFamily" Value="monospace" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalTextAlignment" Value="End" />
        <Setter Property="WidthRequest" Value="110" />
        <Setter Property="Keyboard" Value="Numeric" />
    </Style>

</ResourceDictionary>
