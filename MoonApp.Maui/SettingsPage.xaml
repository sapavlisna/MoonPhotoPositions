<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MoonApp.Maui.SettingsPage"
             Title="Nastavení">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label Text="Datum" />
            <DatePicker x:Name="DateP" Format="dd.MM.yyyy" />
            <Label Text="Okruh [m]" />
            <Entry x:Name="RadiusE" Keyboard="Numeric" />
            <Label Text="Min. okruh [m] (mezikruží)" />
            <Entry x:Name="RadMinE" Keyboard="Numeric" />
            <Label Text="Krok mřížky [m] (menší = jemnější, pomalejší)" />
            <Entry x:Name="ResE" Keyboard="Numeric" />
            <Label Text="Výška očí [m]" />
            <Entry x:Name="EyeE" Keyboard="Numeric" />
            <Label Text="Min. výška objektu [m]" />
            <Entry x:Name="SubjE" Keyboard="Numeric" />
            <Label Text="Tolerance azimutu [°]" />
            <Entry x:Name="AzTolE" Keyboard="Numeric" />
            <Label Text="Výškový pás Měsíce [°]" />
            <Entry x:Name="AltBandE" Keyboard="Numeric" />
            <Button Text="Uložit" Clicked="OnSave" Margin="0,10,0,0" />

            <BoxView HeightRequest="1" Color="#40808080" Margin="0,12,0,4" />
            <Label Text="Motiv aplikace" />
            <Picker x:Name="ThemeP" SelectedIndexChanged="OnThemeChanged">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Podle systému</x:String>
                        <x:String>Světlý</x:String>
                        <x:String>Tmavý</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <BoxView HeightRequest="1" Color="#40808080" Margin="0,12,0,4" />
            <Button x:Name="UpdateBtn" Text="Zkontrolovat aktualizace" Clicked="OnCheckUpdate" />
            <Label x:Name="VersionLbl" FontSize="12" TextColor="#888" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
