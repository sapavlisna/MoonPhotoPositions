<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MoonApp.Maui.SettingsPage"
             Title="Nastavení">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- Datum -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                    <Label Grid.Column="0" Style="{StaticResource SectionTitle}" Text="Datum" VerticalOptions="Center" />
                    <DatePicker Grid.Column="1" x:Name="DateP" Format="dd.MM.yyyy" FontFamily="monospace" />
                </Grid>
            </Border>

            <!-- Oblast výpočtu -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="4">
                    <Label Style="{StaticResource SectionTitle}" Text="Oblast výpočtu" Margin="0,0,0,4" />
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Okruh [m]" VerticalOptions="Center" />
                        <Entry Grid.Column="1" x:Name="RadiusE" Style="{StaticResource ValueEntry}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Min. okruh [m] (mezikruží)" VerticalOptions="Center" />
                        <Entry Grid.Column="1" x:Name="RadMinE" Style="{StaticResource ValueEntry}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Krok mřížky [m]" VerticalOptions="Center" />
                        <Entry Grid.Column="1" x:Name="ResE" Style="{StaticResource ValueEntry}" />
                    </Grid>
                    <Label Text="Menší krok = jemnější výpočet, ale pomalejší." FontSize="11"
                           TextColor="{AppThemeBinding Light={StaticResource MutedL}, Dark={StaticResource MutedD}}" />
                </VerticalStackLayout>
            </Border>

            <!-- Pozorovatel -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="4">
                    <Label Style="{StaticResource SectionTitle}" Text="Pozorovatel" Margin="0,0,0,4" />
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Výška očí [m]" VerticalOptions="Center" />
                        <Entry Grid.Column="1" x:Name="EyeE" Style="{StaticResource ValueEntry}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Min. výška objektu [m]" VerticalOptions="Center" />
                        <Entry Grid.Column="1" x:Name="SubjE" Style="{StaticResource ValueEntry}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Přesnost zarovnání -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="4">
                    <Label Style="{StaticResource SectionTitle}" Text="Přesnost zarovnání" Margin="0,0,0,4" />
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Tolerance azimutu [°]" VerticalOptions="Center" />
                        <Entry Grid.Column="1" x:Name="AzTolE" Style="{StaticResource ValueEntry}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="Výškový pás Měsíce [°]" VerticalOptions="Center" />
                        <Entry Grid.Column="1" x:Name="AltBandE" Style="{StaticResource ValueEntry}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button Text="Uložit" Clicked="OnSave" />

            <!-- Vzhled -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="8">
                    <Label Style="{StaticResource SectionTitle}" Text="Vzhled" />
                    <Border Padding="3" StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SubtleL}, Dark={StaticResource SubtleD}}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="11" /></Border.StrokeShape>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="3">
                            <Button Grid.Column="0" x:Name="SegSys" Text="Systém" FontSize="13" HeightRequest="40"
                                    Padding="0" CornerRadius="9" BackgroundColor="Transparent" Clicked="OnThemePick" />
                            <Button Grid.Column="1" x:Name="SegLight" Text="Světlý" FontSize="13" HeightRequest="40"
                                    Padding="0" CornerRadius="9" BackgroundColor="Transparent" Clicked="OnThemePick" />
                            <Button Grid.Column="2" x:Name="SegDark" Text="Tmavý" FontSize="13" HeightRequest="40"
                                    Padding="0" CornerRadius="9" BackgroundColor="Transparent" Clicked="OnThemePick" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Aktualizace + verze -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="10">
                    <Button x:Name="UpdateBtn" Text="Zkontrolovat aktualizace" Style="{StaticResource Ghost}"
                            FontAttributes="Bold" HeightRequest="44" Clicked="OnCheckUpdate" />
                    <Label x:Name="VersionLbl" Style="{StaticResource Meta}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
